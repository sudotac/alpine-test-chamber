# Maintainer: sudotac <sudo@tofuyard.net>
pkgname=libc-test
pkgver=0_git20260522
pkgrel=0
_pkgrev=b95fe84efa38a146ad32ae02cac224e928926810
pkgdesc="libc test suite"
url="https://repo.or.cz/libc-test.git"
arch="noarch"
license="MIT AND BSD-3-Clause AND GPL-2.0-only"
depends="gcc make musl-dev"
subpackages="$pkgname-doc"
source="
	$pkgname-$pkgver.tar.gz::https://git.tofuyard.net/libc-test.git/snapshot/libc-test-$_pkgrev.tar.gz
	config.mak
	0001-api-unistd-guard-optional-obsolete-_PC-_SC-constants.patch
	0001-Add-feature-gate-for-gets.patch
	"
builddir="$srcdir/$pkgname-$_pkgrev"
options="!check !fhs" # this is a testsuite itself

build() {
	cp "$srcdir"/config.mak "$builddir"/

	make
	make cleanall
}

package() {
	install -Dm 644 COPYRIGHT -t "$pkgdir"/usr/share/licenses/$pkgname/
	install -Dm 644 Makefile -t "$pkgdir"/opt/$pkgname/
	install -Dm 644 config.mak -t "$pkgdir"/opt/$pkgname/
	cp -r src/ "$pkgdir"/opt/$pkgname/
}

