# Maintainer: sudotac <sudo@tofuyard.net>
pkgname=ltp
pkgver=20260529
pkgrel=0
pkgdesc="Linux Test Project"
url="https://linux-test-project.readthedocs.io"
arch="all"
license="GPL-2.0-or-later AND GPL-2.0-only AND LGPL-2.1-or-later AND (GPL-2.0-only OR BSD-3-Clause)"
depends="
	bash
	binutils
	btrfs-progs
	coreutils
	curl
	e2fsprogs-extra
	ethtool
	gcc
	gdb
	gzip
	iproute2-minimal
	keyutils
	nfs-utils
	ntfs-3g
	ntfs-3g-progs
	numactl-tools
	openssl
	parted
	perl
	procps-ng
	python3
	quota-tools
	shadow
	squashfs-tools
	sysstat
	tar
	util-linux-misc
	uuidgen
	xfsprogs
	xorriso
	"
makedepends="
	acl-dev
	autoconf
	automake
	keyutils-dev
	libaio-dev
	libcap-dev
	libmnl-dev
	libselinux-dev
	libsepol-dev
	libtirpc-dev
	linux-headers
	musl-dev
	numactl-dev
	openssl-dev
	patchelf
	pkgconfig
	"
subpackages="$pkgname-doc"
source="https://github.com/linux-test-project/ltp/archive/$pkgver/ltp-$pkgver.tar.gz"
options="!check !fhs" # this is a testsuite itself

prepare() {
	default_prepare
	autoreconf -if

	# https://github.com/linux-test-project/ltp/blob/20260529/ci/alpine.sh#L33-L38
	rm -rfv \
		testcases/kernel/syscalls/fmtmsg/fmtmsg01.c \
		testcases/kernel/syscalls/timer_create/timer_create01.c \
		testcases/kernel/syscalls/timer_create/timer_create03.c
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var \
		--with-open-posix-testsuite
	make

	patchelf --add-rpath '$ORIGIN' testcases/commands/ldd/datafiles/lddfile.out
}

package() {
	make DESTDIR="$pkgdir" install

	install -Dd 755 "$pkgdir"/usr/share/licenses/$pkgname/
	install -m 644 COPYING -t "$pkgdir"/usr/share/licenses/$pkgname/
	install -m 644 testcases/network/can/filter-tests/COPYING "$pkgdir"/usr/share/licenses/$pkgname/COPYING.can
	install -m 644 testcases/open_posix_testsuite/COPYING "$pkgdir"/usr/share/licenses/$pkgname/COPYING.posix
}

sha512sums="
39d2cdb427b848890e3d4d08fe2824c983f4091e12740b0ccc231969d4113d64940c0d20044005fc6e3d3a30fc4b7915ba06237f481c5205630576e7db5827f6  ltp-20260529.tar.gz
"
